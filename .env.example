# ╔═══════════════════════════════════════════════════════════════════╗
# ║  TG Monitor - Backend Environment Variables                       ║
# ║  Bu dosyayi .env olarak kopyala: cp .env.example .env             ║
# ╚═══════════════════════════════════════════════════════════════════╝

# ─── Telegram User Client (Telethon) ─────────────────────────────────
# https://my.telegram.org/auth -> API development tools
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_SESSION_PATH=../session.session

# ─── Telegram Bot (Yonetici bildirim botu) ───────────────────────────
# @BotFather'dan yeni bot olustur, token al
# Kendi user_id'ni @userinfobot'tan al
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_ADMIN_CHAT_ID=your_personal_telegram_user_id

# ─── Anthropic Claude API (opsiyonel) ────────────────────────────────
# Kullanicilar kendi key'lerini Settings'ten ekleyebilir
ANTHROPIC_API_KEY=

# ─── Supabase ────────────────────────────────────────────────────────
# Project Settings > API & Keys (yeni format sb_secret_* veya legacy JWT)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_xxx_or_legacy_jwt

# ─── Field Encryption (Fernet) ───────────────────────────────────────
# Bos birak ilk kurulumda. Asagidaki komutla manuel uretilebilir:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# UYARI: Bir kez set edildikten sonra DEGISTIRME -
# mevcut encrypted api_key/totp_secret'lar okunamaz olur.
ENCRYPTION_KEY=

# ─── Cloudflare Turnstile (CAPTCHA) ──────────────────────────────────
# https://dash.cloudflare.com/?to=/:account/turnstile
# Bos birakirsan login/register CAPTCHA atlanir (dev mode)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ─── Analiz parametreleri ────────────────────────────────────────────
ANALYSIS_BATCH_SIZE=20
ANALYSIS_BATCH_TIMEOUT=60
DAILY_SUMMARY_HOUR=9
ALERT_URGENCY_THRESHOLD=3
